# Required
BRIDGE_API_TOKEN=change-me # arbitrary password for roster and server to share
BOT_KEY=change-me
DISCORD_GUILD_ID=change-me

# Optional defaults
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080
DISCORD_CATEGORY_ID=
BRIDGE_REPLY_TIMEOUT_SECONDS=300
BRIDGE_TYPING_HEARTBEAT_SECONDS=8

# All values must match those in the .env for the discord-server
